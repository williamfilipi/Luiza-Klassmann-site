---
const services = [
  {
    title: "Drenagem Linfática",
    image: "https://www.sbd.org.br/wp-content/uploads/2022/06/Drenagem-linfatica-e-benefica-para-a-saude-shutterstock-1.webp",
    description: "Estimula o sistema linfático para reduzir edemas, eliminar toxinas e melhorar a circulação.",
    tag: "Saúde & Estética"
  },
  {
    title: "Liberação Miofascial",
    image: "https://clubepaineiras.org.br/wp-content/uploads/2024/02/27-3-Liberacao-Miofascial.jpg",
    description: "Atua nas fáscias musculares para devolver mobilidade e aliviar tensões profundas.",
    tag: "Performance"
  },
  {
    title: "Ventosas",
    image: "https://blog.vitoriahoteis.com.br/wp-content/uploads/2025/09/sessao-terapia-ventosas-copos-costas.webp",
    description: "Técnica milenar que melhora a circulação sanguínea e libera toxinas musculares.",
    tag: "Recuperação"
  },
  {
    title: "Pedras Quentes",
    image: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTSjjHposbntb78kw3yhlym8FCT7R2NiAHTZA&s",
    description: "Proporciona relaxamento profundo e alívio do estresse através do calor terapêutico.",
    tag: "Bem-estar"
  },
  {
    title: "Massagem Modeladora",
    image: "https://biocap.com.br/wp-content/uploads/2023/11/foto_blog_Novembro_1024x641_01.png",
    description: "Técnica vigorosa que auxilia na redução de medidas e melhora o contorno corporal.",
    tag: "Estética"
  },
  {
    title: "Skin Care",
    image: "https://www.clinicaleger.com.br/wp-content/uploads/2020/01/rotina-skincare-cuidados-com-a-pele.jpg",
    description: "Protocolos personalizados para manter a saúde e o brilho natural da sua pele.",
    tag: "Beleza"
  },
  {
    title: "Acupuntura",
    image: "https://medicinasa.com.br/wp-content/uploads/2020/11/acupuntura.jpg",
    description: "Equilíbrio energético e alívio de dores através de pontos estratégicos do corpo.",
    tag: "Equilíbrio"
  },
  {
    title: "Microagulhamento",
    image: "https://hamonir.com.br/wp-content/uploads/2022/02/microagulhamento-no-rosto-1300x731.jpg",
    description: "Estimula a produção de colágeno para rejuvenescimento e tratamento de cicatrizes.",
    tag: "Rejuvenescimento"
  }
];
// Split into two rows of 4
const row1 = services.slice(0, 4);
const row2 = services.slice(4);
---
<section id="servicos" class="py-20 bg-[#FDFBF7]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-14">
      <span class="text-brand-terracotta text-[10px] font-bold uppercase tracking-[0.3em] mb-4 block">
        Nossas Especialidades
      </span>
      <h2 class="text-5xl md:text-6xl mb-6">
        Serviços de <span class="text-brand-sage italic font-light">Alta Performance</span>
      </h2>
      <p class="text-brand-ink/50 max-w-2xl mx-auto font-light text-lg">
        Tratamentos exclusivos desenvolvidos para proporcionar resultados reais e uma experiência sensorial única.
      </p>
    </div>

    <!-- Row 1 carousel -->
    <div class="svc-carousel mb-10" data-carousel="1">
      <div class="svc-track overflow-hidden">
        <div class="svc-slides flex gap-6 transition-transform duration-500 ease-in-out">
          {row1.map((service) => (
            <div class="svc-slide flex-none group bg-white rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5">
              <div class="h-56 overflow-hidden relative">
                <img src={service.image} alt={service.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" referrerpolicy="no-referrer" loading="lazy" />
                <div class="absolute top-4 left-4">
                  <span class="px-3 py-1 bg-white/90 backdrop-blur-md rounded-full text-[9px] font-bold uppercase tracking-widest text-brand-ink shadow-sm">{service.tag}</span>
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">{service.title}</h3>
                <p class="text-brand-ink/50 text-sm leading-relaxed mb-5 font-light">{service.description}</p>
                <a href="#" data-service={service.title} class="whatsapp-service-btn inline-flex items-center justify-center w-full py-3 bg-brand-terracotta text-white rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:bg-brand-sage transition-all shadow-lg shadow-brand-terracotta/20">
                  Agendar
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
      <!-- Arrows row 1 -->
      <button class="svc-prev absolute top-1/2 -translate-y-1/2 -left-4 md:-left-5 z-10 w-10 h-10 rounded-full bg-white border border-brand-gold/20 shadow-md flex items-center justify-center text-brand-ink hover:bg-brand-gold hover:text-white transition-all" aria-label="Anterior">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button class="svc-next absolute top-1/2 -translate-y-1/2 -right-4 md:-right-5 z-10 w-10 h-10 rounded-full bg-white border border-brand-gold/20 shadow-md flex items-center justify-center text-brand-ink hover:bg-brand-gold hover:text-white transition-all" aria-label="Próximo">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <div class="svc-dots flex justify-center gap-2 mt-6"></div>
    </div>

    <!-- Row 2 carousel -->
    <div class="svc-carousel" data-carousel="2">
      <div class="svc-track overflow-hidden">
        <div class="svc-slides flex gap-6 transition-transform duration-500 ease-in-out">
          {row2.map((service) => (
            <div class="svc-slide flex-none group bg-white rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5">
              <div class="h-56 overflow-hidden relative">
                <img src={service.image} alt={service.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" referrerpolicy="no-referrer" loading="lazy" />
                <div class="absolute top-4 left-4">
                  <span class="px-3 py-1 bg-white/90 backdrop-blur-md rounded-full text-[9px] font-bold uppercase tracking-widest text-brand-ink shadow-sm">{service.tag}</span>
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">{service.title}</h3>
                <p class="text-brand-ink/50 text-sm leading-relaxed mb-5 font-light">{service.description}</p>
                <a href="#" data-service={service.title} class="whatsapp-service-btn inline-flex items-center justify-center w-full py-3 bg-brand-terracotta text-white rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:bg-brand-sage transition-all shadow-lg shadow-brand-terracotta/20">
                  Agendar
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
      <button class="svc-prev absolute top-1/2 -translate-y-1/2 -left-4 md:-left-5 z-10 w-10 h-10 rounded-full bg-white border border-brand-gold/20 shadow-md flex items-center justify-center text-brand-ink hover:bg-brand-gold hover:text-white transition-all" aria-label="Anterior">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button class="svc-next absolute top-1/2 -translate-y-1/2 -right-4 md:-right-5 z-10 w-10 h-10 rounded-full bg-white border border-brand-gold/20 shadow-md flex items-center justify-center text-brand-ink hover:bg-brand-gold hover:text-white transition-all" aria-label="Próximo">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <div class="svc-dots flex justify-center gap-2 mt-6"></div>
    </div>
  </div>
</section>

<style>
  .svc-carousel {
    position: relative;
  }
</style>

<script>
  const GAP = 24;

  function visibleCols(): number {
    const w = window.innerWidth;
    if (w < 640) return 1;
    if (w < 1024) return 2;
    return 4;
  }

  function initCarousel(carousel: HTMLElement) {
    const track    = carousel.querySelector<HTMLElement>('.svc-track')!;
    const slidesEl = carousel.querySelector<HTMLElement>('.svc-slides')!;
    const slides   = carousel.querySelectorAll<HTMLElement>('.svc-slide');
    const dotsEl   = carousel.querySelector<HTMLElement>('.svc-dots')!;
    const prevBtn  = carousel.querySelector<HTMLButtonElement>('.svc-prev')!;
    const nextBtn  = carousel.querySelector<HTMLButtonElement>('.svc-next')!;

    const total = slides.length;
    let cols = visibleCols();
    let cur = 0;

    function sw(): number {
      return (track.offsetWidth - (cols - 1) * GAP) / cols;
    }

    function setSizes() {
      cols = visibleCols();
      const w = sw();
      slides.forEach(s => { s.style.width = `${w}px`; });
    }

    function buildDots() {
      const maxStep = total - cols;
      dotsEl.innerHTML = '';
      for (let i = 0; i <= maxStep; i++) {
        const d = document.createElement('button');
        d.setAttribute('aria-label', `Posição ${i + 1}`);
        d.addEventListener('click', () => goTo(i));
        dotsEl.appendChild(d);
      }
    }

    function updateDots() {
      const maxStep = total - cols;
      dotsEl.querySelectorAll('button').forEach((d, i) => {
        const active = i === cur;
        d.className = `h-2 rounded-full transition-all duration-300 ${active ? 'bg-brand-gold w-5' : 'bg-brand-gold/30 w-2'}`;
      });
    }

    function goTo(idx: number) {
      const maxStep = total - cols;
      cur = Math.max(0, Math.min(idx, maxStep));
      slidesEl.style.transform = `translateX(-${cur * (sw() + GAP)}px)`;
      updateDots();
    }

    function init() {
      setSizes();
      buildDots();
      cur = 0;
      goTo(0);
    }

    prevBtn.addEventListener('click', () => goTo(cur - 1));
    nextBtn.addEventListener('click', () => goTo(cur + 1));
    window.addEventListener('resize', init);

    // Swipe
    let startX = 0;
    track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', e => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(cur + (diff > 0 ? 1 : -1));
    });

    init();
  }

  document.querySelectorAll<HTMLElement>('.svc-carousel').forEach(initCarousel);

  // WhatsApp links
  const PHONE = '5551993975325';
  document.querySelectorAll<HTMLAnchorElement>('.whatsapp-service-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const service = btn.getAttribute('data-service') ?? '';
      const message = encodeURIComponent(`Olá! Quero agendar: ${service}`);
      window.open(`https://wa.me/${PHONE}?text=${message}`, '_blank', 'noopener,noreferrer');
    });
  });
</script>
