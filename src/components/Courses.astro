---
// Courses section
const courseImages = [
  {
    src: "/curso1.avif",
    alt: "Formação em Massoterapia - aula prática",
    pos: "center",
  },
  {
    src: "/curso3.avif",
    alt: "Curso presencial de massoterapia",
    pos: "center 30%",
  },
  { src: "/curso4.avif", alt: "Turma de formação VIP", pos: "center 30%" },
  {
    src: "/curso5.avif",
    alt: "Técnicas avançadas de massoterapia",
    pos: "center 30%",
  },
  {
    src: "/curso7.avif",
    alt: "Aula prática com tutoria personalizada",
    pos: "center",
  },
];
---

<section
  id="cursos"
  class="py-12 md:py-20 bg-brand-ink text-white relative overflow-hidden"
>
  <!-- Background blobs — animated/living -->
  <div
    class="absolute inset-0 pointer-events-none overflow-hidden"
    aria-hidden="true"
  >
    <!-- Main gold blob — slow drift top-left -->
    <div
      class="blob-gold absolute top-[-15%] left-[-8%] w-[65%] h-[65%] rounded-full blur-[90px] opacity-25"
    >
    </div>
    <!-- Secondary terracotta blob — slow drift bottom-right -->
    <div
      class="blob-terracotta absolute bottom-[-15%] right-[-8%] w-[65%] h-[65%] rounded-full blur-[90px] opacity-20"
    >
    </div>
    <!-- Accent gold blob — center, small pulse -->
    <div
      class="blob-accent absolute top-[30%] left-[40%] w-[35%] h-[35%] rounded-full blur-[70px] opacity-15"
    >
    </div>
    <!-- Shimmer streaks overlay -->
    <div class="blob-shimmer absolute inset-0 opacity-5"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Header -->
    <div class="courses-reveal text-center mb-10 md:mb-16">
      <span
        class="text-brand-gold text-[10px] md:text-sm font-bold uppercase tracking-[0.4em] mb-4 block"
      >
        Mentoria Profissional
      </span>
      <h2 class="text-5xl md:text-6xl max-w-4xl mx-auto mb-6 leading-[1.1]">
        Mentoria para profissionais que desejam ir <span
          class="text-brand-gold italic font-light">além da técnica!</span
        >
      </h2>
      <p
        class="text-white/60 text-xl max-w-4xl mx-auto leading-relaxed font-light mb-4"
      >
        Sabemos que o mercado no qual estamos inseridos, está cada vez mais
        exigente e cresce de forma exponencial. Para desenvolver segurança nos
        seus atendimentos e fazer a <strong
          class="text-white font-bold tracking-wider">DIFERENÇA</strong
        >, é necessário desenvolver o raciocínio clínico e saber extrair o
        máximo de cada possibilidade que a Terapia Manual oferece.
      </p>
      <p
        class="text-white/60 text-xl max-w-4xl mx-auto leading-relaxed font-light mb-4"
      >
        As mentorias são desenvolvidas de forma personalizada, ou seja, conforme
        a necessidade individual do aluno.
      </p>
      <p
        class="text-brand-gold text-2xl max-w-4xl mx-auto leading-relaxed font-serif mt-8"
      >
        "Me conta as tuas necessidades que eu monto um planejamento exclusivo
        para você!"
      </p>
    </div>

    <!-- Features row -->
    <div
      class="courses-reveal grid grid-cols-2 md:grid-cols-4 gap-4 mb-12 max-w-3xl mx-auto"
    >
      {
        [
          { label: "Metodologia Prática", icon: "check" },
          { label: "Certificação VIP", icon: "award" },
          { label: "Turmas Reduzidas", icon: "users" },
          { label: "Suporte Vitalício", icon: "heart" },
        ].map((item) => (
          <div class="benefit-card flex flex-col items-center gap-3 px-6 py-5 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm cursor-default">
            <svg
              class="text-brand-gold w-6 h-6"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              {item.icon === "check" && (
                <>
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                  <path d="m9 11 3 3L22 4" />
                </>
              )}
              {item.icon === "award" && (
                <>
                  <circle cx="12" cy="8" r="6" />
                  <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11" />
                </>
              )}
              {item.icon === "users" && (
                <>
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                  <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </>
              )}
              {item.icon === "heart" && (
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
              )}
            </svg>
            <span class="text-sm font-medium uppercase tracking-widest text-white/80 text-center">
              {item.label}
            </span>
          </div>
        ))
      }
    </div>

    <!-- Photo gallery grid -->
    <div
      class="courses-gallery grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mb-16"
    >
      {
        courseImages.map((img, i) => (
          <div
            class={`gallery-item overflow-hidden rounded-2xl group ${i === 0 ? "md:col-span-2 row-span-2" : ""}`}
            style={`--delay: ${i * 80}ms`}
          >
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              style={`aspect-ratio: ${i === 0 ? "1/1" : "4/3"}; object-position: ${img.pos}`}
              loading="lazy"
              decoding="async"
              width={i === 0 ? 600 : 400}
              height={i === 0 ? 600 : 300}
            />
          </div>
        ))
      }
    </div>

    <!-- CTA -->
    <div class="courses-reveal text-center">
      <a
        href="https://wa.me/5551993975325?text=Ol%C3%A1%21%20Gostaria%20de%20saber%20mais%20sobre%20a%20mentoria%20profissional."
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-10 py-5 bg-whatsapp-green hover:bg-[#128C7E] text-white rounded-full font-bold text-sm tracking-widest uppercase transition-all shadow-xl shadow-[#25D366]/20 bg-[#25D366]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          fill="currentColor"
          viewBox="0 0 16 16"
          class="mr-3"
          ><path
            d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"
          ></path></svg
        >
        Falar sobre Mentoria
      </a>
    </div>
  </div>
</section>

<style>
  .courses-reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s ease,
      transform 0.7s ease;
  }
  .courses-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .benefit-card {
    border: 1px solid rgba(138, 154, 121, 0.2);
    transition:
      transform 0.3s ease,
      background-color 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      filter 0.3s ease;
  }
  .benefit-card:hover {
    transform: translateY(-4px) scale(1.04);
    background-color: rgba(197, 160, 89, 0.15);
    border-color: rgba(197, 160, 89, 0.4);
    box-shadow: 0 0 24px rgba(197, 160, 89, 0.2);
  }
  .gallery-item {
    opacity: 0;
    transform: scale(0.95);
    transition:
      opacity 0.6s ease var(--delay, 0ms),
      transform 0.6s ease var(--delay, 0ms),
      box-shadow 0.4s;
  }
  .gallery-item.visible {
    opacity: 1;
    transform: scale(1);
  }
  .gallery-item:hover {
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }
</style>
<script>
  const reveals = document.querySelectorAll(".courses-reveal");
  const revObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("visible");
      });
    },
    { threshold: 0.15 },
  );
  reveals.forEach((e) => revObs.observe(e));

  const galleryItems = document.querySelectorAll(".gallery-item");
  const galObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("visible");
      });
    },
    { threshold: 0.1 },
  );
  galleryItems.forEach((e) => galObs.observe(e));
</script>
